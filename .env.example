# ══════════════════════════════════════════════════════
#  StarKit — Laravel 13 + Inertia v3 + Vue 3
#  Copia este archivo: cp .env.example .env
#  Luego ejecuta: php artisan key:generate
# ══════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────
APP_NAME="StarKit"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Lima
APP_LOCALE=es
APP_FALLBACK_LOCALE=en

# ── Base de datos ─────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=starterkit
DB_USERNAME=root
DB_PASSWORD=

# ── Cache & Sesiones ──────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# ── Colas (Queue) ─────────────────────────────────────
# Opciones: sync | database | redis
# sync   → sin worker, procesa en el mismo request (desarrollo)
# database → requiere: php artisan queue:table && php artisan migrate
# redis  → requiere Redis instalado
QUEUE_CONNECTION=database

# ── Correo ────────────────────────────────────────────
# Para desarrollo usa "log" o "mailtrap"
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@starterkit.test"
MAIL_FROM_NAME="${APP_NAME}"

# ── Autenticación 2FA (manual por correo) ─────────────
TWO_FACTOR_CODE_LENGTH=6
TWO_FACTOR_CODE_EXPIRES_MINUTES=10

# ── Cloudinary (avatares) ─────────────────────────────
# Obtén tus credenciales en: https://cloudinary.com
# Dejar vacío si no usas uploads de avatar
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=starterkit_avatars

# ── Redis (opcional) ──────────────────────────────────
# Necesario si QUEUE_CONNECTION=redis o CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Logging ───────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Vite / Frontend ───────────────────────────────────
# No modificar — solo en caso de conflicto de puertos
VITE_APP_NAME="${APP_NAME}"
