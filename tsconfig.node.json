{
    "compilerOptions": {
        "composite": true,
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "noEmit": false,
        "strict": true
    },
    "include": [
        "vite.config.ts",
        "vite.config.d.ts"
    ]
}
